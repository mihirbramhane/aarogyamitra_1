# Copy to .env.local (gitignored). NEVER commit real keys.
# Use the "anon public" key from Supabase Dashboard -> Project Settings -> API.
# Never put the service_role key here — anything NEXT_PUBLIC_* ships to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
AGENT_BACKEND_URL=http://localhost:8000

# Google Maps JavaScript API key (Maps JavaScript API enabled), used by
# components/HospitalMap.tsx to render hospital pins. Ships to the browser
# (NEXT_PUBLIC_*), so restrict it to your domain(s) via an HTTP referrer
# restriction in Google Cloud Console. Without it, HospitalMap falls back to
# a plain list.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
